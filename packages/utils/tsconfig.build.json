{
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "target": "ES2022",
    "declaration": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": false,
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": ".",
    "paths": {
      "@/config/*": ["../common/src/config/*"],
      "@/config/configuration": ["../common/src/config/configuration"],
      "@/config/dto/*": ["../common/src/config/dto/*"],
      "@/config/validation": ["../common/src/config/validation"],
      "@/filter/*": ["../common/src/filter/*"],
      "@/filter/exception/api.exception": ["../common/src/filter/exception/api.exception"],
      "@/clients/internal/file-storage": ["../clients/src/internal/file-storage"],
      "@repo/contracts/errors": ["../../../models.dofe.ai/packages/contracts/src/errors/index"],
      "@repo/contracts/*": ["../../../models.dofe.ai/packages/contracts/src/*"],
      "@repo/contracts": ["../../../models.dofe.ai/packages/contracts/src"],
      "@repo/utils/*": ["../../../models.dofe.ai/packages/utils/*"],
      "@repo/utils": ["../../../models.dofe.ai/packages/utils"],
      "@repo/constants": ["../../../models.dofe.ai/packages/constants/src"],
      "@dofe/infra-common": ["../common/src"],
      "@dofe/infra-common/*": ["../common/src/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "**/*.spec.ts", "**/*.test.ts"]
}
