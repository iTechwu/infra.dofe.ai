{
  "name": "@dofe/infra-prisma",
  "version": "0.1.30",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./db-metrics": {
      "types": "./dist/db-metrics/index.d.ts",
      "default": "./dist/db-metrics/index.js"
    },
    "./db-metrics/src": {
      "types": "./dist/db-metrics/src/index.d.ts",
      "default": "./dist/db-metrics/src/index.js"
