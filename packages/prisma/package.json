    "@willsoto/nestjs-prometheus": "^6.0.0",
    "class-validator": "^0.14.1 || ^0.15.0",
    "ioredis": "^5.0.0",
    "nest-winston": "^1.9.7",
    "pg": "^8.0.0",
    "prom-client": "^15.0.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "winston": "^3.13.0"
