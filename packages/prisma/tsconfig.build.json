{
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "target": "ES2022",
    "declaration": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": false,
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": ".",
    "paths": {
      "@/middleware/*": ["../common/src/middleware/*"],
      "@/prisma/*": ["./src/prisma/*"],
      "@/prisma-read/*": ["./src/prisma-read/*"],
      "@/prisma-write/*": ["./src/prisma-write/*"],
      "@/utils/*": ["../utils/src/*", "../common/src/*"],
      "@app/redis": ["../redis/src"],
      "@app/redis/*": ["../redis/src/*"],
      "@dofe/infra-common": ["../common/src"],
      "@dofe/infra-common/*": ["../common/src/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "**/*.spec.ts", "**/*.test.ts"]
}
