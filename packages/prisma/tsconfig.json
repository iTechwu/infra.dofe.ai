{
  "compilerOptions": {
    "module": "Node16",
    "moduleResolution": "Node16",
    "target": "ES2022",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@/prisma/*": ["./src/prisma/*"],
      "@/prisma-read/*": ["./src/prisma-read/*"],
      "@/prisma-write/*": ["./src/prisma-write/*"]
    }
  },
  "include": ["src/**/*"]
}
