{
  "name": "@dofe/infra-contracts",
  "version": "0.1.19",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./*": {
      "types": ["./dist/*.d.ts", "./dist/*/index.d.ts"],
      "default": ["./dist/*.js", "./dist/*/index.js"]
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "type": "commonjs",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "license": "UNLICENSED"
}
