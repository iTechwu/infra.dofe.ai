{
  "name": "@dofe/infra-contracts",
  "version": "0.1.25",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./constants": {
      "types": "./dist/constants.d.ts",
      "default": "./dist/constants.js"
    },
    "./error-codes": {
      "types": "./dist/error-codes.d.ts",
      "default": "./dist/error-codes.js"
    },
    "./providers": {
      "types": "./dist/providers.d.ts",
      "default": "./dist/providers.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "default": "./dist/types.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "postbuild": "node ../../scripts/generate-exports.mjs"
  },
  "type": "commonjs",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "license": "UNLICENSED"
}
