{
  "name": "@dofe/infra-docker",
  "version": "0.1.32",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./docker-image.module": {
      "types": "./dist/docker-image.module.d.ts",
      "default": "./dist/docker-image.module.js"
    },
    "./docker-image.service": {
      "types": "./dist/docker-image.service.d.ts",
      "default": "./dist/docker-image.service.js"
    },
    "./docker-orphan-cleaner.service": {
      "types": "./dist/docker-orphan-cleaner.service.d.ts",
      "default": "./dist/docker-orphan-cleaner.service.js"
    },
    "./docker-runtime.module": {
      "types": "./dist/docker-runtime.module.d.ts",
      "default": "./dist/docker-runtime.module.js"
    },
    "./docker-stats.service": {
      "types": "./dist/docker-stats.service.d.ts",
      "default": "./dist/docker-stats.service.js"
    },
    "./docker.module": {
      "types": "./dist/docker.module.d.ts",
      "default": "./dist/docker.module.js"
    },
    "./docker.service": {
      "types": "./dist/docker.service.d.ts",
      "default": "./dist/docker.service.js"
    },
    "./docker.utils": {
      "types": "./dist/docker.utils.d.ts",
      "default": "./dist/docker.utils.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "default": "./dist/types.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "postbuild": "node ../../scripts/generate-exports.mjs"
  },
  "peerDependencies": {
    "@dofe/infra-common": "^0.1.29",
    "@dofe/infra-utils": "^0.1.29",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "dockerode": "^4.0.0",
    "nest-winston": "^1.9.7",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3"
  },
  "type": "commonjs",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "license": "UNLICENSED"
}
