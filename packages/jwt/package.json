{
  "name": "@dofe/infra-jwt",
  "version": "0.1.26",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./jwt.module": {
      "types": "./dist/jwt.module.d.ts",
      "default": "./dist/jwt.module.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "postbuild": "node ../../scripts/generate-exports.mjs"
  },
  "peerDependencies": {
    "@dofe/infra-common": "^0.1.25",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/jwt": "^11.0.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0"
  },
  "devDependencies": {
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3"
  },
  "type": "commonjs",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "license": "UNLICENSED"
}
