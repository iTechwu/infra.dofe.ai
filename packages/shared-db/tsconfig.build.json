{
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "target": "ES2022",
    "declaration": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": false,
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": ".",
    "paths": {
      "@/decorators/*": ["../common/src/decorators/*"],
      "@/prisma/*": ["../prisma/src/prisma/*"],
      "@/prisma/prisma.module": ["../prisma/src/prisma/prisma.module"],
      "@app/prisma": ["../prisma/src/prisma"],
      "@app/prisma/*": ["../prisma/src/*"],
      "@dofe/infra-common": ["../common/src"],
      "@dofe/infra-common/*": ["../common/src/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "**/*.spec.ts", "**/*.test.ts"]
}
