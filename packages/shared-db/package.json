{
  "name": "@dofe/infra-shared-db",
  "version": "0.1.23",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./country-code/country-code.module": {
      "types": "./dist/country-code/country-code.module.d.ts",
      "default": "./dist/country-code/country-code.module.js"
    },
    "./country-code/country-code.service": {
      "types": "./dist/country-code/country-code.service.d.ts",
      "default": "./dist/country-code/country-code.service.js"
    },
    "./transaction-context": {
      "types": "./dist/transaction-context.d.ts",
      "default": "./dist/transaction-context.js"
    },
    "./transaction.module": {
      "types": "./dist/transaction.module.d.ts",
      "default": "./dist/transaction.module.js"
    },
    "./transactional-service.base": {
      "types": "./dist/transactional-service.base.d.ts",
      "default": "./dist/transactional-service.base.js"
    },
    "./unit-of-work.service": {
      "types": "./dist/unit-of-work.service.d.ts",
      "default": "./dist/unit-of-work.service.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "postbuild": "node ../../scripts/generate-exports.mjs"
  },
  "peerDependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@prisma/client": "^7.0.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0"
  },
  "dependencies": {
    "@dofe/infra-common": "workspace:*",
    "@dofe/infra-prisma": "workspace:*",
    "@dofe/infra-redis": "workspace:*"
  },
  "devDependencies": {
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3"
  },
  "type": "commonjs",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "license": "UNLICENSED"
}
