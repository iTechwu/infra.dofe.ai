{
  "name": "@dofe/infra-rabbitmq",
  "version": "0.1.24",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./dto/rabbitmq.dto": {
      "types": "./dist/dto/rabbitmq.dto.d.ts",
      "default": "./dist/dto/rabbitmq.dto.js"
    },
    "./rabbitmq-events.constants": {
      "types": "./dist/rabbitmq-events.constants.d.ts",
      "default": "./dist/rabbitmq-events.constants.js"
    },
    "./rabbitmq-events.module": {
      "types": "./dist/rabbitmq-events.module.d.ts",
      "default": "./dist/rabbitmq-events.module.js"
    },
    "./rabbitmq-events.service": {
      "types": "./dist/rabbitmq-events.service.d.ts",
      "default": "./dist/rabbitmq-events.service.js"
    },
    "./rabbitmq.module": {
      "types": "./dist/rabbitmq.module.d.ts",
      "default": "./dist/rabbitmq.module.js"
    },
    "./rabbitmq.service": {
      "types": "./dist/rabbitmq.service.d.ts",
      "default": "./dist/rabbitmq.service.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "postbuild": "node ../../scripts/generate-exports.mjs"
  },
  "peerDependencies": {
    "@dofe/infra-utils": "workspace:*",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "amqp-connection-manager": "^5.0.0",
    "amqplib": "^1.0.0",
    "class-validator": "^0.14.1",
    "nest-winston": "^1.9.7",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "winston": "^3.13.0"
  },
  "dependencies": {
    "@dofe/infra-common": "workspace:*",
    "@dofe/infra-prisma": "workspace:*",
    "@dofe/infra-redis": "workspace:*"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.8",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3"
  },
  "type": "commonjs",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "license": "UNLICENSED"
