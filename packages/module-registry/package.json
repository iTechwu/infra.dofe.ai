{
  "name": "@dofe/infra-module-registry",
  "version": "0.1.32",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./dynamic-feature.module": {
      "types": "./dist/dynamic-feature.module.d.ts",
      "default": "./dist/dynamic-feature.module.js"
    },
    "./module-registry.module": {
      "types": "./dist/module-registry.module.d.ts",
      "default": "./dist/module-registry.module.js"
    },
    "./module-registry.service": {
      "types": "./dist/module-registry.service.d.ts",
      "default": "./dist/module-registry.service.js"
    },
    "./module-scanner.service": {
      "types": "./dist/module-scanner.service.d.ts",
      "default": "./dist/module-scanner.service.js"
    },
    "./register-module.decorator": {
      "types": "./dist/register-module.decorator.d.ts",
      "default": "./dist/register-module.decorator.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "postbuild": "node ../../scripts/generate-exports.mjs"
  },
  "peerDependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0"
  },
  "devDependencies": {
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3"
  },
  "type": "commonjs",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "license": "UNLICENSED"
}
