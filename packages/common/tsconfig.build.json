{
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "target": "ES2022",
    "declaration": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": false,
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": ".",
    "paths": {
      "@/common/*": ["./src/*"],
      "@/config/*": ["./src/config/*"],
      "@/config/configuration": ["./src/config/configuration"],
      "@/config/dto/*": ["./src/config/dto/*"],
      "@/config/validation": ["./src/config/validation"],
      "@/filter/*": ["./src/filter/*"],
      "@/decorators/*": ["./src/decorators/*"],
      "@/interceptor/*": ["./src/interceptor/*"],
      "@/middleware/*": ["./src/middleware/*"],
      "@/pipes/*": ["./src/pipes/*"],
      "@/enums/*": ["./src/enums/*"],
      "@/ts-rest/*": ["./src/ts-rest/*"],
      "@/adapters/*": ["./src/adapters/*"],
      "@/utils/*": ["../utils/src/*", "./src/*"],
      "@/libs/*": ["./src/*"],
      "@/clients/internal/file-storage": ["../clients/src/internal/file-storage"],
      "@/clients/internal/crypt": ["../clients/src/internal/crypt"],
      "@/shared-db/*": ["../shared-db/src/*"],
      "@/prisma/*": ["../prisma/src/prisma/*"],
      "@app/redis": ["../redis/src"],
      "@app/redis/*": ["../redis/src/*"],
      "@app/shared-services/*": ["../shared-services/src/*"],
      "@repo/contracts/errors": ["../../../models.dofe.ai/packages/contracts/src/errors/index"],
      "@repo/contracts/*": ["../../../models.dofe.ai/packages/contracts/src/*"],
      "@repo/contracts": ["../../../models.dofe.ai/packages/contracts/src"],
      "@repo/constants": ["../../../models.dofe.ai/packages/constants/src"],
      "@repo/utils": ["../../../models.dofe.ai/packages/utils/src"],
      "@dofe/infra-common": ["./src"],
      "@dofe/infra-common/*": ["./src/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "**/*.spec.ts", "**/*.test.ts"]
}
