{
  "name": "@dofe/infra-vector",
  "version": "0.1.23",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./embedding.service": {
      "types": "./dist/embedding.service.d.ts",
      "default": "./dist/embedding.service.js"
    },
    "./knowledge-base-vikingdb.client": {
      "types": "./dist/knowledge-base-vikingdb.client.d.ts",
      "default": "./dist/knowledge-base-vikingdb.client.js"
    },
    "./vector.module": {
      "types": "./dist/vector.module.d.ts",
      "default": "./dist/vector.module.js"
    },
    "./vikingdb-client.service": {
      "types": "./dist/vikingdb-client.service.d.ts",
      "default": "./dist/vikingdb-client.service.js"
    },
    "./vikingdb.types": {
      "types": "./dist/vikingdb.types.d.ts",
      "default": "./dist/vikingdb.types.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "postbuild": "node ../../scripts/generate-exports.mjs"
  },
  "peerDependencies": {
    "@dofe/infra-common": "workspace:*",
    "@nestjs/axios": "^4.0.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@volcengine/openapi": "^1.0.0",
    "axios": "^1.0.0",
    "nest-winston": "^1.9.7",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3"
  },
  "type": "commonjs",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "license": "UNLICENSED"
}
