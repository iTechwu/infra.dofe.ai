{
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "target": "ES2022",
    "declaration": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": false,
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": ".",
    "paths": {
      "@/config/*": ["../common/src/config/*"],
      "@/config/configuration": ["../common/src/config/configuration"],
      "@/config/dto/*": ["../common/src/config/dto/*"],
      "@/config/validation": ["../common/src/config/validation"],
      "@/decorators/*": ["../common/src/decorators/*"],
      "@/filter/*": ["../common/src/filter/*"],
      "@/filter/exception/api.exception": ["../common/src/filter/exception/api.exception"],
      "@/utils/*": ["../utils/src/*", "../common/src/*"],
      "@app/clients/internal/*": ["../clients/src/internal/*"],
      "@app/jwt/jwt.module": ["../jwt/src/jwt.module"],
      "@app/prisma": ["../prisma/src/prisma"],
      "@app/prisma/*": ["../prisma/src/*"],
      "@app/rabbitmq": ["../rabbitmq/src"],
      "@app/rabbitmq/*": ["../rabbitmq/src/*"],
      "@app/redis": ["../redis/src"],
      "@app/redis/*": ["../redis/src/*"],
      "@app/shared-services/file-storage": ["./src/file-storage"],
      "@app/shared-services/ip-geo": ["./src/ip-geo"],
      "@app/shared-services/streaming-asr": ["./src/streaming-asr"],
      "@app/shared-services/*": ["./src/*"],
      "@dofe/infra-common": ["../common/src"],
      "@dofe/infra-common/*": ["../common/src/*"],
      "@repo/contracts/errors": ["../../../models.dofe.ai/packages/contracts/src/errors/index"],
      "@repo/contracts/*": ["../../../models.dofe.ai/packages/contracts/src/*"],
      "@repo/contracts": ["../../../models.dofe.ai/packages/contracts/src"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "**/*.spec.ts", "**/*.test.ts"]
}
