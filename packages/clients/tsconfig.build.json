{
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "target": "ES2022",
    "declaration": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": false,
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": ".",
    "paths": {
      "@/config/*": ["../common/src/config/*"],
      "@/config/configuration": ["../common/src/config/configuration"],
      "@/config/dto/*": ["../common/src/config/dto/*"],
      "@/config/validation": ["../common/src/config/validation"],
      "@/filter/*": ["../common/src/filter/*"],
      "@/filter/exception/api.exception": ["../common/src/filter/exception/api.exception"],
      "@/utils/*": ["../utils/src/*", "../common/src/*"],
      "@app/clients/internal/*": ["./src/internal/*"],
      "@app/clients/plugin": ["./src/plugin"],
      "@app/clients/plugin/*": ["./src/plugin/*"],
      "@app/redis": ["../redis/src"],
      "@app/redis/*": ["../redis/src/*"],
      "@app/shared-services/file-storage": ["../shared-services/src/file-storage"],
      "@app/shared-services/*": ["../shared-services/src/*"],
      "@dofe/infra-common": ["../common/src"],
      "@dofe/infra-common/*": ["../common/src/*"],
      "@repo/contracts": ["../../../models.dofe.ai/packages/contracts/src"],
      "@repo/contracts/*": ["../../../models.dofe.ai/packages/contracts/src/*"],
      "@repo/contracts/errors": ["../../../models.dofe.ai/packages/contracts/src/errors/index"],
      "@repo/contracts/schemas/sse.schema": ["../../../models.dofe.ai/packages/contracts/src/schemas/sse.schema"],
      "@repo/utils": ["../../../models.dofe.ai/packages/utils/src"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "**/*.spec.ts", "**/*.test.ts"]
}
