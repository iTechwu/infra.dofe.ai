{
  "name": "@dofe/infra-clients",
  "version": "0.1.22",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./*": {
      "types": [
        "./dist/internal/*.d.ts",
        "./dist/internal/*/index.d.ts"
      ],
      "default": [
        "./dist/internal/*.js",
        "./dist/internal/*/index.js",
        "./dist/internal/*"
      ]
    },
    "./plugin": {
      "types": "./dist/plugin/index.d.ts",
      "default": "./dist/plugin/index.js"
    },
    "./plugin/*": {
      "types": [
        "./dist/plugin/*.d.ts",
        "./dist/plugin/*/index.d.ts"
      ],
      "default": [
        "./dist/plugin/*.js",
        "./dist/plugin/*/index.js",
        "./dist/plugin/*"
      ]
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "peerDependencies": {
    "@alicloud/dysmsapi20170525": "^3.0.0",
    "@alicloud/openapi-client": "^0.4.0",
    "@aws-sdk/client-s3": "^3.978.0",
    "@aws-sdk/client-sts": "^3.1024.0",
    "@aws-sdk/s3-request-presigner": "^3.978.0",
    "@dofe/infra-contracts": "^0.1.21",
    "@dofe/infra-docker": "^0.1.21",
    "@google-cloud/storage": "^7.12.0",
    "@larksuiteoapi/node-sdk": "^1.30.0",
    "@nestjs/axios": "^4.0.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@volcengine/openapi": "^1.0.0",
    "@volcengine/tos-sdk": "^2.7.6",
    "axios": "^1.7.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "form-data": "^4.0.0",
    "js-yaml": "^4.1.0",
    "lodash": "^4.17.21",
    "nest-winston": "^1.9.7",
    "nodemailer": "^8.0.0",
    "nodemailer-sendcloud-transport": "^0.0.2",
    "qiniu": "^7.12.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "tencentcloud-sdk-nodejs-sms": "^4.0.0",
    "uuid": "^14.0.0",
    "winston": "^3.13.0",
    "ws": "^8.18.3",
    "zod": "^4.3.6"
  },
  "dependencies": {
    "@dofe/infra-common": "^0.1.21",
    "@dofe/infra-redis": "^0.1.21",
    "@dofe/infra-utils": "^0.1.21"
  },
  "devDependencies": {
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3"
  },
  "type": "commonjs",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "license": "UNLICENSED"
}
