// Test fixture for @dofe/infra-prisma-crud-generator
// Covers: @id, @unique, @@unique, @relation, isDeleted, createdAt, optional fields,
// dotted annotations (@db.Xxx), nested parens, @map, enums

enum UserRole {
  ADMIN
  EDITOR
  VIEWER
}

enum ContentStatus {
  DRAFT    @map("draft")
  PUBLISHED @map("published")
  ARCHIVED @map("archived")
}

model User {
  id        String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  email     String   @unique @db.VarChar(255)
  name      String?
  role      UserRole @default(VIEWER)
  isDeleted Boolean  @default(false) @map("is_deleted")
  createdAt DateTime @default(now())
  posts     Post[]
}

model Post {
  id        String        @id @default(uuid())
  title     String        @db.VarChar(255)
  content   String?
  status    ContentStatus @default(DRAFT)
  authorId  String
  author    User          @relation(fields: [authorId], references: [id])
  isDeleted Boolean       @default(false)
  createdAt DateTime      @default(now())
  tags      PostTag[]

  @@unique([title, authorId])
}

model PostTag {
  id     String @id @default(uuid())
  postId String
  tagId  String
  post   Post   @relation(fields: [postId], references: [id])
  tag    Tag    @relation(fields: [tagId], references: [id])
}

model Tag {
  id    String    @id @default(uuid())
  name  String    @unique
  posts PostTag[]
}

// Model without @id — should be skipped by generator
model AuditLog {
  action     String
  userId     String
  recordedAt DateTime @default(now())
}
