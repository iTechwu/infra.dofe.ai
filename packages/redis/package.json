{
  "name": "@dofe/infra-redis",
  "version": "0.1.22",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./*": {
      "types": [
        "./dist/*.d.ts",
        "./dist/*/index.d.ts"
      ],
      "default": [
        "./dist/*.js",
        "./dist/*/index.js",
        "./dist/*"
      ]
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "peerDependencies": {
    "@dofe/infra-contracts": "^0.1.21",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "ioredis": "^5.0.0",
    "nest-winston": "^1.9.7",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "uuid": "^14.0.0",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3"
  },
  "type": "commonjs",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "license": "UNLICENSED"
}
