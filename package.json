{
  "name": "dofe-infra",
  "version": "0.0.0",
  "private": true,
  "description": "DofeAI shared infrastructure libraries",
  "engines": {
    "node": ">=20.19.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.25.0",
  "scripts": {
    "build": "bash scripts/build-all.sh",
    "build:legacy": "pnpm -r --stream run build",
    "clean": "pnpm -r --stream run clean",
    "lint": "eslint 'packages/*/src/**/*.ts' --fix",
    "typecheck": "pnpm -r --stream run typecheck",
    "verify:storage-feature-boundary": "node scripts/check-storage-feature-boundary.mjs",
    "publish:all": "bash scripts/publish-all.sh",
    "publish": "bash scripts/publish-single.sh",
    "publish:clients": "bash scripts/publish-single.sh clients",
    "publish:common": "bash scripts/publish-single.sh common",
    "publish:config": "bash scripts/publish-single.sh config",
    "publish:contracts": "bash scripts/publish-single.sh contracts",
    "publish:contracts-base": "bash scripts/publish-single.sh contracts-base",
    "publish:docker": "bash scripts/publish-single.sh docker",
    "publish:i18n": "bash scripts/publish-single.sh i18n",
    "publish:jwt": "bash scripts/publish-single.sh jwt",
    "publish:module-registry": "bash scripts/publish-single.sh module-registry",
    "publish:prisma": "bash scripts/publish-single.sh prisma",
    "publish:prisma-crud-generator": "bash scripts/publish-single.sh prisma-crud-generator",
    "publish:rabbitmq": "bash scripts/publish-single.sh rabbitmq",
    "publish:redis": "bash scripts/publish-single.sh redis",
    "publish:shared-db": "bash scripts/publish-single.sh shared-db",
    "publish:shared-services": "bash scripts/publish-single.sh shared-services",
    "publish:sso-browser": "bash scripts/publish-single.sh sso-browser",
    "publish:utils": "bash scripts/publish-single.sh utils",
    "publish:vector": "bash scripts/publish-single.sh vector",
    "publish:web-runtime": "bash scripts/publish-single.sh web-runtime",
    "publish:workspace": "bash scripts/publish-single.sh workspace"
  },
  "pnpm": {
    "peerDependencyRules": {
      "allowedVersions": {
        "@dofe/*": "*",
        "bcrypt": ">=5.1.0",
        "dotenv": ">=16.0.0",
        "eslint": "10"
      },
      "missingPeersAllowed": {
        "@dofe/infra-contracts": true,
        "@dofe/infra-common": true,
        "@dofe/infra-utils": true,
        "@dofe/infra-redis": true,
        "@dofe/infra-prisma": true,
        "@dofe/infra-jwt": true,
        "@dofe/infra-i18n": true,
        "@dofe/infra-clients": true,
        "@dofe/infra-rabbitmq": true,
        "@dofe/infra-shared-db": true,
        "@dofe/infra-shared-services": true
      }
    },
    "onlyBuiltDependencies": [
      "@nestjs/core"
    ]
  },
  "devDependencies": {
    "@dofe/infra-contracts": "workspace:*",
    "@dofe/infra-docker": "workspace:*",
    "@dofe/infra-workspace": "workspace:*",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.27",
    "@nestjs/platform-fastify": "^11.1.27",
    "@types/node": "^25.9.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "7.8.2",
    "typescript": "^6.0.3",
    "zod": "^4.4.3"
  }
}
