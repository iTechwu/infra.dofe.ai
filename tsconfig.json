{
  "extends": "./tsconfig.build-all.json",
  "compilerOptions": {
    "noEmit": true,
    "strictNullChecks": false,
    "strictPropertyInitialization": false,
    "noImplicitAny": false,
    "types": ["node"]
  },
  "exclude": [
    "node_modules",
    "packages/*/node_modules",
    "packages/*/dist",
    "**/*.spec.ts",
    "**/*.test.ts"
  ]
}
