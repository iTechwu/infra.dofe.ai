# Hoist Prisma runtime packages so generated client can resolve them
# registry=https://registry.npmmirror.com
public-hoist-pattern[]=@prisma/*

# @deprecated: shamefully-hoist is a blunt instrument that hides dependency issues.
# It was needed for legacy pnpm behavior; modern pnpm works with public-hoist-pattern.
# Planned removal: 2026-12-31 (requires build verification first).
shamefully-hoist=true

auto-install-peers=true
strict-peer-dependencies=false
