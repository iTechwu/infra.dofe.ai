{
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "module": "Node16",
    "moduleResolution": "Node16",
    "target": "ES2022",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": false,
    "outDir": "./_dist_tmp",
    "rootDir": "./packages",
    "baseUrl": ".",
    "paths": {
      "@dofe/infra-common": ["packages/common/src"],
      "@dofe/infra-common/*": ["packages/common/src/*"],
      "@dofe/infra-contracts": ["packages/contracts/src"],
      "@dofe/infra-contracts/*": ["packages/contracts/src/*"],
      "@dofe/infra-clients": ["packages/clients/src"],
      "@dofe/infra-clients/*": ["packages/clients/src/*"],
      "@dofe/infra-prisma": ["packages/prisma/src"],
      "@dofe/infra-prisma/*": ["packages/prisma/src/*"],
      "@dofe/infra-redis": ["packages/redis/src"],
      "@dofe/infra-redis/*": ["packages/redis/src/*"],
      "@dofe/infra-rabbitmq": ["packages/rabbitmq/src"],
      "@dofe/infra-rabbitmq/*": ["packages/rabbitmq/src/*"],
      "@dofe/infra-jwt": ["packages/jwt/src"],
      "@dofe/infra-jwt/*": ["packages/jwt/src/*"],
      "@dofe/infra-utils": ["packages/utils/src"],
      "@dofe/infra-utils/*": ["packages/utils/src/*"],
      "@dofe/infra-i18n": ["packages/i18n/src"],
      "@dofe/infra-i18n/*": ["packages/i18n/src/*"],
      "@dofe/infra-shared-db": ["packages/shared-db/src"],
      "@dofe/infra-shared-db/*": ["packages/shared-db/src/*"],
      "@dofe/infra-shared-services": ["packages/shared-services/src"],
      "@dofe/infra-shared-services/*": ["packages/shared-services/src/*"],
      "@dofe/sso-browser": ["packages/sso-browser/src"],
      "@dofe/sso-browser/*": ["packages/sso-browser/src/*"],
      "@dofe/infra-docker": ["packages/docker/src"],
      "@dofe/infra-docker/*": ["packages/docker/src/*"],
      "@dofe/infra-vector": ["packages/vector/src"],
      "@dofe/infra-vector/*": ["packages/vector/src/*"],
      "@dofe/infra-contracts-base": ["packages/contracts-base/src"],
      "@dofe/infra-contracts-base/*": ["packages/contracts-base/src/*"],
      "@dofe/infra-module-registry": ["packages/module-registry/src"],
      "@dofe/infra-module-registry/*": ["packages/module-registry/src/*"],
      "@dofe/infra-prisma-crud-generator": ["packages/prisma-crud-generator/src"],
      "@dofe/infra-prisma-crud-generator/*": ["packages/prisma-crud-generator/src/*"],
      "@dofe/infra-web-runtime": ["packages/web-runtime/src"],
      "@dofe/infra-web-runtime/*": ["packages/web-runtime/src/*"],
      "@dofe/infra-workspace": ["packages/workspace/src"],
      "@dofe/infra-workspace/*": ["packages/workspace/src/*"],
      "@dofe/infra-runtime": ["packages/runtime/src"],
      "@dofe/infra-runtime/*": ["packages/runtime/src/*"]
    }
  },
  "include": [
    "packages/*/src/**/*"
  ],
  "exclude": [
    "node_modules",
    "packages/*/node_modules",
    "packages/*/dist",
    "**/*.spec.ts",
    "**/*.test.ts",
    "packages/clients/src/internal/feishu/**/*.ts"
  ]
}
