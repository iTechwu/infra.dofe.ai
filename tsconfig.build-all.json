{
  "compilerOptions": {
    "module": "Node16",
    "moduleResolution": "Node16",
    "target": "ES2022",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": false,
    "outDir": "./_dist_tmp",
    "rootDir": "./packages",
    "baseUrl": ".",
    "paths": {
      "@/common/*": ["packages/common/src/*"],
      "@/config/*": ["packages/common/src/config/*"],
      "@/config/configuration": ["packages/common/src/config/configuration"],
      "@/config/dto/*": ["packages/common/src/config/dto/*"],
      "@/config/validation": ["packages/common/src/config/validation"],
      "@/filter/*": ["packages/common/src/filter/*"],
      "@/filter/exception/api.exception": ["packages/common/src/filter/exception/api.exception"],
      "@/decorators/*": ["packages/common/src/decorators/*"],
      "@/interceptor/*": ["packages/common/src/interceptor/*"],
      "@/middleware/*": ["packages/common/src/middleware/*"],
      "@/pipes/*": ["packages/common/src/pipes/*"],
      "@/enums/*": ["packages/common/src/enums/*"],
      "@/ts-rest/*": ["packages/common/src/ts-rest/*"],
      "@/adapters/*": ["packages/common/src/adapters/*"],
      "@/utils/*": ["packages/utils/src/*", "packages/common/src/*"],
      "@/libs/*": ["packages/common/src/*"],
      "@/shared-db/*": ["packages/shared-db/src/*"],
      "@/prisma/*": ["packages/prisma/src/prisma/*"],
      "@/prisma-read/*": ["packages/prisma/src/prisma-read/*"],
      "@/prisma-write/*": ["packages/prisma/src/prisma-write/*"],
      "@/clients/*": ["packages/clients/src/*"],
      "@/i18n/*": ["packages/i18n/src/*"],
      "@app/redis": ["packages/redis/src"],
      "@app/redis/*": ["packages/redis/src/*"],
      "@app/redis/dto/redis.dto": ["packages/redis/src/dto/redis.dto"],
      "@app/prisma": ["packages/prisma/src/prisma"],
      "@app/prisma/*": ["packages/prisma/src/*"],
      "@app/jwt": ["packages/jwt/src"],
      "@app/jwt/*": ["packages/jwt/src/*"],
      "@app/rabbitmq": ["packages/rabbitmq/src"],
      "@app/rabbitmq/*": ["packages/rabbitmq/src/*"],
      "@app/shared-db": ["packages/shared-db/src"],
      "@app/shared-db/*": ["packages/shared-db/src/*"],
      "@app/shared-services/file-storage": ["packages/shared-services/src/file-storage"],
      "@app/shared-services/ip-geo": ["packages/shared-services/src/ip-geo"],
      "@app/shared-services/streaming-asr": ["packages/shared-services/src/streaming-asr"],
      "@app/shared-services/*": ["packages/shared-services/src/*"],
      "@app/clients/internal/*": ["packages/clients/src/internal/*"],
      "@app/clients/plugin": ["packages/clients/src/plugin"],
      "@app/clients/plugin/*": ["packages/clients/src/plugin/*"],
      "@app/i18n": ["packages/i18n/src"],
      "@app/i18n/*": ["packages/i18n/src/*"],
      "@dofe/infra-common": ["packages/common/src"],
      "@dofe/infra-common/*": ["packages/common/src/*"],
      "@dofe/infra-clients": ["packages/clients/src"],
      "@dofe/infra-clients/*": ["packages/clients/src/*"],
      "@dofe/infra-prisma": ["packages/prisma/src"],
      "@dofe/infra-prisma/*": ["packages/prisma/src/*"],
      "@dofe/infra-redis": ["packages/redis/src"],
      "@dofe/infra-redis/*": ["packages/redis/src/*"],
      "@dofe/infra-rabbitmq": ["packages/rabbitmq/src"],
      "@dofe/infra-rabbitmq/*": ["packages/rabbitmq/src/*"],
      "@dofe/infra-jwt": ["packages/jwt/src"],
      "@dofe/infra-jwt/*": ["packages/jwt/src/*"],
      "@dofe/infra-utils": ["packages/utils/src"],
      "@dofe/infra-utils/*": ["packages/utils/src/*"],
      "@dofe/infra-i18n": ["packages/i18n/src"],
      "@dofe/infra-i18n/*": ["packages/i18n/src/*"],
      "@dofe/infra-shared-db": ["packages/shared-db/src"],
      "@dofe/infra-shared-db/*": ["packages/shared-db/src/*"],
      "@dofe/infra-shared-services": ["packages/shared-services/src"],
      "@dofe/infra-shared-services/*": ["packages/shared-services/src/*"],
      "@repo/contracts/errors": ["../../../models.dofe.ai/packages/contracts/src/errors/index"],
      "@repo/contracts/*": ["../../../models.dofe.ai/packages/contracts/src/*"],
      "@repo/contracts": ["../../../models.dofe.ai/packages/contracts/src"],
      "@repo/contracts/schemas/sse.schema": ["../../../models.dofe.ai/packages/contracts/src/schemas/sse.schema"],
      "@repo/utils/*": ["../../../models.dofe.ai/packages/utils/*"],
      "@repo/utils": ["../../../models.dofe.ai/packages/utils"],
      "@repo/constants": ["../../../models.dofe.ai/packages/constants/src"],
      "@repo/validators": ["../../../models.dofe.ai/packages/validators/src"]
    }
  },
  "include": [
    "packages/*/src/**/*"
  ],
  "exclude": [
    "node_modules",
    "packages/*/node_modules",
    "packages/*/dist",
    "**/*.spec.ts",
    "**/*.test.ts",
    "packages/common/src/file.util.ts"
  ]
}
